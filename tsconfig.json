{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "@finderos/agent": ["packages/agent/src"],
      "@finderos/scanner": ["packages/scanner/src"],
      "@finderos/sdk": ["packages/sdk/src"],
      "@finderos/contracts": ["packages/contracts/src"]
    }
  },
  "exclude": ["node_modules", "dist", "**/*.test.ts"]
}
